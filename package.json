{
  "name": "aion2-dashboard",
  "version": "2.1.3",
  "private": true,
  "license": "MIT",
  "description": "AION 2 multi-character progress dashboard",
  "author": "SouNd",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "smoke:ui": "node scripts/ui-smoke.mjs",
    "capture:ui-baseline:phase0": "node scripts/ui-baseline-phase0-capture.mjs",
    "capture:ui-baseline:phase1": "node scripts/ui-baseline-phase0-capture.mjs --out-dir artifacts/ui-baseline/phase1",
    "capture:ui-baseline:phase2": "node scripts/ui-baseline-phase0-capture.mjs --out-dir artifacts/ui-baseline/phase2",
    "capture:ui-baseline:phase3": "node scripts/ui-baseline-phase0-capture.mjs --out-dir artifacts/ui-baseline/phase3",
    "capture:ui-baseline:phase4": "node scripts/ui-baseline-phase0-capture.mjs --out-dir artifacts/ui-baseline/phase4",
    "test:smoke": "npm run test:unit && npm run build && npm run smoke:ui",
    "check:prepackage": "node scripts/prepackage-check.mjs",
    "check:release-yml": "node scripts/check-release-latest-yml.mjs",
    "prepare:icon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-icon.ps1",
    "dist:win": "npm run prepare:icon && npm run check:prepackage && electron-builder --win nsis portable --publish never && npm run check:release-yml",
    "dist:win:publish": "npm run prepare:icon && npm run check:prepackage && electron-builder --win nsis portable --publish always && npm run check:release-yml"
  },
  "dependencies": {
    "@gutenye/ocr-node": "^1.4.8",
    "chinese-conv": "^4.0.0",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^2.3.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.9.3",
    "vite": "^5.4.11",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.sound.aion2dashboard",
    "productName": "AION2 Dashboard",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "icon.png",
        "to": "icon.png"
      },
      {
        "from": "制作管理.md",
        "to": "制作管理.md"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@gutenye/ocr-models/assets/**"
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SouNdmys",
        "repo": "AION2-Dashboard"
      }
    ]
  }
}
